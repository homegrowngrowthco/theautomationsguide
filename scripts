// ── Main ──────────────────────────────────────────────────────────────────────
async function main() {
  if (NOTION_TOKEN === 'NOTION_TOKEN') {
    console.error('ERROR: Set NOTION_TOKEN before running.\n  NOTION_TOKEN=secret_xxx NOTION_PARENT_PAGE_ID=abc123 node create-notion-plan.js');
    process.exit(1);
  }
  if (NOTION_PARENT_PAGE_ID === 'NOTION_PARENT_PAGE_ID') {
    console.error('ERROR: Set NOTION_PARENT_PAGE_ID before running.\n  NOTION_TOKEN=secret_xxx NOTION_PARENT_PAGE_ID=abc123 node create-notion-plan.js');
    process.exit(1);
  }

  console.log('\n🚀  Creating 90-Day Launch Plan in Notion…\n');

  // 1. Parent page
  console.log('Creating parent page…');
  await delay();
  const parentPage = await notion.pages.create({
    parent:     { type: 'page_id', page_id: NOTION_PARENT_PAGE_ID },
    icon:       { type: 'emoji', emoji: '🗺️' },
    properties: { title: { title: rt('The Automations Guide — 90 Day Launch Plan') } },
    children:   parentPageChildren(),
  });
  console.log(`  ✓ Parent page: ${parentPage.id}\n`);

  // 2. Phase sub-pages
  for (const phase of PHASES) {
    console.log(`Creating "${phase.title}"…`);

    await delay();
    const subPage = await notion.pages.create({
      parent:     { type: 'page_id', page_id: parentPage.id },
      icon:       { type: 'emoji', emoji: phase.emoji },
      properties: { title: { title: rt(phase.title) } },
      children:   subPageChildren(phase),
    });
    console.log(`  ✓ Sub-page: ${subPage.id}`);

    // Inline database
    await delay();
    const db = await notion.databases.create({
      parent:     { type: 'page_id', page_id: subPage.id },
      title:      rt(`${phase.title} — Tasks`),
      is_inline:  true,
      properties: dbProperties(),
    });
    console.log(`  ✓ Database: ${db.id}`);

    // Task rows
    console.log(`  Adding ${phase.tasks.length} tasks…`);
    for (let i = 0; i < phase.tasks.length; i++) {
      const t = phase.tasks[i];
      await delay();
      await notion.pages.create({
        parent: { database_id: db.id },
        properties: {
          'Task':     { title: rt(t.task) },
          'Week':     { select: { name: t.week } },
          'Day':      { number: t.day },
          'Category': { select: { name: t.category } },
          'Priority': { select: { name: t.priority } },
          'Status':   { select: { name: 'Not Started' } },
          'Notes':    { rich_text: t.notes ? rt(t.notes) : [] },
        },
      });
      process.stdout.write(`\r  Tasks added: ${i + 1}/${phase.tasks.length}   `);
    }
    console.log(`\n  ✓ All tasks added for "${phase.title}"\n`);
  }

  console.log('✅  Done! Your 90-Day Launch Plan is live in Notion.');
  console.log(`\n   🔗 https://notion.so/${parentPage.id.replace(/-/g, '')}\n`);
}

main().catch(err => {
  console.error('\n❌  Error:', err.message);
  if (err.body) console.error('   Details:', JSON.stringify(err.body, null, 2));
  process.exit(1);
});
